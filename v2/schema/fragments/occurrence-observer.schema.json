{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dictionary.local/v2/fragments/occurrence-observer.schema.json",
  "title": "Occurrence observer response",
  "type": "object",
  "additionalProperties": false,
  "required": ["root_envelope_id", "language", "observations"],
  "properties": {
    "root_envelope_id": {
      "type": "string",
      "pattern": "^root_[0-9]{6}(--root_[0-9]{6})*$"
    },
    "language": { "enum": ["en", "tr"] },
    "observations": {
      "type": "array",
      "items": { "$ref": "#/$defs/occurrenceObservation" }
    }
  },
  "$defs": {
    "sourceRef": { "type": "string", "minLength": 3, "maxLength": 1200 },
    "prose": { "type": "string", "minLength": 10, "maxLength": 3000 },
    "occurrenceObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "statement", "evidence_refs"],
      "properties": {
        "category": {
          "enum": ["recurrent_pattern", "exception", "grammar", "translation_risk", "other"]
        },
        "statement": { "$ref": "#/$defs/prose" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    }
  }
}
