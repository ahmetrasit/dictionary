{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dictionary.local/v2/encyclopedia-entry.schema.json",
  "title": "Dictionary v2 target-language encyclopedia entry",
  "description": "One authored encyclopedia entry for one root envelope and one target language.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_by",
    "entry_id",
    "language",
    "status",
    "root_envelope_id",
    "root_ids",
    "provenance",
    "root_profile",
    "branches",
    "occurrence_evidence"
  ],
  "properties": {
    "schema_version": { "const": 4 },
    "generated_by": { "const": "v2/scripts/assemble_entry.py" },
    "entry_id": {
      "type": "string",
      "pattern": "^root_[0-9]{6}(--root_[0-9]{6})*/(en|tr)$"
    },
    "language": { "enum": ["en", "tr"] },
    "status": { "enum": ["draft", "reviewed", "published"] },
    "root_envelope_id": { "$ref": "#/$defs/rootEnvelopeId" },
    "root_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/rootId" }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "root_profile": { "$ref": "#/$defs/rootProfile" },
    "branches": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/branch" }
    },
    "occurrence_evidence": { "$ref": "#/$defs/occurrenceEvidence" }
  },
  "$defs": {
    "rootId": {
      "type": "string",
      "pattern": "^root_[0-9]{6}$"
    },
    "rootEnvelopeId": {
      "type": "string",
      "pattern": "^root_[0-9]{6}(--root_[0-9]{6})*$"
    },
    "branchId": {
      "type": "string",
      "pattern": "^B[0-9]{3}$"
    },
    "sourceRef": {
      "type": "string",
      "minLength": 3,
      "maxLength": 1200
    },
    "shortText": {
      "type": "string",
      "minLength": 2,
      "maxLength": 500
    },
    "shortProse": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1200
    },
    "prose": {
      "type": "string",
      "minLength": 10,
      "maxLength": 3000
    },
    "sourceText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 3000
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_path",
        "packet_sha256",
        "evidence_index_path",
        "evidence_index_sha256",
        "furuq_path",
        "furuq_sha256"
      ],
      "properties": {
        "packet_path": {
          "type": "string",
          "pattern": "^data/output/root_packets/root_[0-9]{6}(--root_[0-9]{6})*\\.json$"
        },
        "packet_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "evidence_index_path": {
          "type": "string",
          "pattern": "^v2/output/branch_evidence/root_[0-9]{6}(--root_[0-9]{6})*/index\\.json$"
        },
        "evidence_index_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "furuq_path": {
          "type": "string",
          "minLength": 8,
          "maxLength": 500
        },
        "furuq_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "root_task_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "rootProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transliteration",
        "summary",
        "polysemy",
        "organization",
        "branch_count",
        "collocation_weight",
        "collocation_note"
      ],
      "properties": {
        "transliteration": { "$ref": "#/$defs/shortText" },
        "summary": { "$ref": "#/$defs/shortProse" },
        "polysemy": { "enum": ["monosemic", "polysemic"] },
        "organization": {
          "enum": ["monosemic", "radial", "multi_branch", "mixed", "uncertain"]
        },
        "branch_count": { "type": "integer", "minimum": 1 },
        "collocation_weight": { "enum": ["low", "moderate", "high", "unknown"] },
        "collocation_note": { "$ref": "#/$defs/shortProse" }
      }
    },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_id",
        "branch_id",
        "branch_image_ar",
        "what_is_ar",
        "what_is_not_ar",
        "source_phrase_ar",
        "image_transliteration",
        "summary",
        "lexical_realizations",
        "usage_notes",
        "evidence_qualifiers",
        "source_discussion",
        "dictionary_basis",
        "glosses",
        "arabic_neighbor_distinctions",
        "neighbor_coverage"
      ],
      "properties": {
        "root_id": { "$ref": "#/$defs/rootId" },
        "branch_id": { "$ref": "#/$defs/branchId" },
        "branch_image_ar": { "$ref": "#/$defs/sourceText" },
        "what_is_ar": { "$ref": "#/$defs/sourceText" },
        "what_is_not_ar": { "$ref": "#/$defs/sourceText" },
        "source_phrase_ar": { "$ref": "#/$defs/sourceText" },
        "image_transliteration": { "$ref": "#/$defs/shortText" },
        "summary": { "$ref": "#/$defs/shortProse" },
        "concept_map": { "$ref": "#/$defs/conceptMap" },
        "lexical_realizations": {
          "type": "array",
          "items": { "$ref": "#/$defs/lexicalRealization" }
        },
        "usage_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/usageNote" }
        },
        "evidence_qualifiers": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceQualifier" }
        },
        "source_discussion": { "$ref": "#/$defs/sourceDiscussion" },
        "dictionary_basis": { "$ref": "#/$defs/dictionaryBasis" },
        "glosses": { "$ref": "#/$defs/glossSelection" },
        "arabic_neighbor_distinctions": {
          "type": "array",
          "description": "Author-ordered by reader-facing importance; item 0 is the key distinction used by compact dictionary projections.",
          "minItems": 0,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/neighborDistinction" }
        },
        "neighbor_coverage": { "$ref": "#/$defs/neighborCoverage" }
      }
    },
    "lexicalRealization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lexical_unit_id",
        "expression_ar",
        "unit_kind",
        "sense_ar",
        "evidence_refs",
        "quran_form"
      ],
      "properties": {
        "lexical_unit_id": { "type": "string", "minLength": 3, "maxLength": 100 },
        "expression_ar": { "$ref": "#/$defs/shortText" },
        "unit_kind": { "type": "string", "minLength": 2, "maxLength": 100 },
        "sense_ar": { "$ref": "#/$defs/shortText" },
        "target_gloss": { "$ref": "#/$defs/shortText" },
        "target_rendering_kind": { "enum": ["ordinary", "proper_name"] },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "quran_form": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["stem_ar", "tag"],
          "properties": {
            "stem_ar": { "$ref": "#/$defs/shortText" },
            "tag": { "type": "string", "minLength": 1, "maxLength": 100 }
          }
        }
      }
    },
    "usageNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "statement", "evidence_refs"],
      "properties": {
        "kind": {
          "enum": ["morphology", "syntax", "valency", "register", "constraint", "technical"]
        },
        "statement": { "$ref": "#/$defs/shortProse" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    },
    "evidenceQualifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "statement", "source_refs"],
      "properties": {
        "type": { "enum": ["disputed", "rare", "technical"] },
        "statement": { "$ref": "#/$defs/shortProse" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    },
    "sourceDiscussion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discussion", "evidence_refs", "examples", "disagreement"],
      "properties": {
        "discussion": { "$ref": "#/$defs/prose" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "examples": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/sourceExample" }
        },
        "details": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceDetail" }
        },
        "disagreement": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["summary", "source_refs"],
          "properties": {
            "summary": { "$ref": "#/$defs/shortProse" },
            "source_refs": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/sourceRef" }
            }
          }
        }
      }
    },
    "sourceDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary", "source_ids", "source_refs"],
      "properties": {
        "kind": {
          "enum": [
            "example",
            "disagreement",
            "restriction",
            "extension",
            "implication",
            "derivation",
            "sole_attestation"
          ]
        },
        "summary": { "$ref": "#/$defs/shortProse" },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    },
    "conceptMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definition", "facets"],
      "properties": {
        "definition": { "$ref": "#/$defs/shortProse" },
        "facets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/conceptFacet" }
        }
      }
    },
    "conceptFacet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facet_id", "role", "statement", "claim_ids"],
      "properties": {
        "facet_id": { "type": "string", "pattern": "^F[0-9]{3}$" },
        "role": {
          "enum": [
            "core",
            "specialization",
            "extension",
            "associated_use",
            "example",
            "source_variant"
          ]
        },
        "statement": { "$ref": "#/$defs/shortProse" },
        "claim_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^lu_[0-9]{3,}$" }
        }
      }
    },
    "sourceExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arabic", "note", "source_refs"],
      "properties": {
        "arabic": { "$ref": "#/$defs/shortText" },
        "note": { "$ref": "#/$defs/shortProse" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    },
    "dictionaryBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dictionary_count", "passage_count", "sources"],
      "properties": {
        "dictionary_count": { "type": "integer", "minimum": 1 },
        "passage_count": { "type": "integer", "minimum": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/dictionarySource" }
        }
      }
    },
    "dictionarySource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "dictionary_name", "source_refs"],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "dictionary_name": { "$ref": "#/$defs/shortText" },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "base_definition",
              "corroboration",
              "boundary",
              "derivation",
              "example",
              "disagreement",
              "sole_attestation",
              "reading"
            ]
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "contribution": { "$ref": "#/$defs/shortProse" }
      }
    },
    "glossSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantic_definition", "selected", "excluded"],
      "properties": {
        "semantic_definition": { "$ref": "#/$defs/shortProse" },
        "concept": { "$ref": "#/$defs/selectedGloss" },
        "contextual": {
          "type": "array",
          "maxItems": 4,
          "items": { "$ref": "#/$defs/selectedGloss" }
        },
        "selected": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/selectedGloss" }
        },
        "excluded": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/excludedGloss" }
        }
      }
    },
    "selectedGloss": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "text",
        "loanword_status",
        "usage_role",
        "applicability",
        "error_profile"
      ],
      "properties": {
        "rank": { "type": "integer", "minimum": 1, "maximum": 5 },
        "text": { "$ref": "#/$defs/shortText" },
        "loanword_status": { "enum": ["none", "common", "specialist"] },
        "usage_role": {
          "enum": ["general", "contextual", "explanatory", "technical_term", "proper_name"]
        },
        "selection_role": {
          "enum": ["primary_concept_gloss", "contextual_gloss"]
        },
        "facet_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^F[0-9]{3}$" }
        },
        "applicability": { "$ref": "#/$defs/shortProse" },
        "error_profile": { "$ref": "#/$defs/errorProfile" }
      }
    },
    "excludedGloss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "category", "exclusion_reason", "error_profile"],
      "properties": {
        "text": { "$ref": "#/$defs/shortText" },
        "category": { "enum": ["alternative", "common_loanword", "confusable"] },
        "exclusion_reason": { "$ref": "#/$defs/shortProse" },
        "error_profile": { "$ref": "#/$defs/errorProfile" }
      }
    },
    "errorProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fit", "preserves", "loses", "adds", "collision"],
      "properties": {
        "fit": {
          "enum": ["none", "narrowing", "broadening", "displacement", "drifted_loanword"]
        },
        "preserves": { "$ref": "#/$defs/shortProse" },
        "loses": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "adds": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "collision": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 }
      }
    },
    "neighborDistinction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "neighbor_root_id",
        "neighbor_branch_id",
        "expression_ar",
        "expression_transliteration",
        "gloss",
        "shared_zone",
        "distinction",
        "basis",
        "evidence_refs"
      ],
      "properties": {
        "neighbor_root_id": { "$ref": "#/$defs/rootId" },
        "neighbor_branch_id": { "$ref": "#/$defs/branchId" },
        "relation_type": {
          "description": "Primary semantic relation verified from the compared branch concepts; network signals are nomination evidence only.",
          "enum": [
            "synonym",
            "near_synonym",
            "antonym",
            "polarity_pair",
            "near_neighbor",
            "same_field",
            "thematic",
            "other"
          ]
        },
        "boundary_match": {
          "enum": ["exact", "partial", "opposed", "field_only", "thematic_only"]
        },
        "focus_only": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "neighbor_only": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "expression_ar": { "$ref": "#/$defs/shortText" },
        "expression_transliteration": { "$ref": "#/$defs/shortText" },
        "gloss": { "$ref": "#/$defs/shortText" },
        "shared_zone": { "$ref": "#/$defs/shortProse" },
        "distinction": { "$ref": "#/$defs/prose" },
        "basis": { "const": "furuq_branch_comparison" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    },
    "neighborCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_count", "assessment", "note"],
      "properties": {
        "candidate_count": { "type": "integer", "minimum": 1 },
        "assessment": {
          "enum": [
            "none_useful",
            "complete",
            "single_sufficient",
            "legacy_minimum_unverified"
          ]
        },
        "note": { "$ref": "#/$defs/shortProse" }
      }
    },
    "occurrenceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_path",
        "artifact_sha256",
        "generator",
        "alignment_path",
        "alignment_sha256",
        "alignment_generator",
        "observations",
        "summary",
        "forms",
        "ayahs",
        "occurrences"
      ],
      "properties": {
        "artifact_path": {
          "type": "string",
          "pattern": "^v2/output/occurrences/root_[0-9]{6}(--root_[0-9]{6})*\\.(en|tr)\\.md$"
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "generator": { "const": "v2/scripts/render_occurrences.py" },
        "alignment_path": {
          "type": "string",
          "pattern": "^v2/output/alignments/root_[0-9]{6}(--root_[0-9]{6})*\\.json$"
        },
        "alignment_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "alignment_generator": { "const": "v2/scripts/render_occurrences.py" },
        "observations": {
          "type": "array",
          "items": { "$ref": "#/$defs/occurrenceObservation" }
        },
        "summary": { "$ref": "#/$defs/occurrenceSummary" },
        "forms": {
          "type": "array",
          "items": { "$ref": "#/$defs/occurrenceForm" }
        },
        "ayahs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ayahRecord" }
        },
        "occurrences": {
          "type": "array",
          "items": { "$ref": "#/$defs/occurrenceRecord" }
        }
      }
    },
    "occurrenceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["morpheme_count", "word_count", "ayah_count", "surah_count"],
      "properties": {
        "morpheme_count": { "type": "integer", "minimum": 0 },
        "word_count": { "type": "integer", "minimum": 0 },
        "ayah_count": { "type": "integer", "minimum": 0 },
        "surah_count": { "type": "integer", "minimum": 0 }
      }
    },
    "occurrenceForm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["form_id", "lemma_ar", "stem_ar", "pos", "measure", "morph_features", "occurrence_count"],
      "properties": {
        "form_id": { "type": "string", "pattern": "^F[0-9]{3}$" },
        "lemma_ar": { "type": "string" },
        "stem_ar": { "type": "string" },
        "pos": { "type": "string" },
        "measure": { "type": "string" },
        "morph_features": { "type": "string" },
        "occurrence_count": { "type": "integer", "minimum": 1 }
      }
    },
    "ayahRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ayah_ref", "surface_ar"],
      "properties": {
        "ayah_ref": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
        "surface_ar": { "type": "string", "minLength": 1 }
      }
    },
    "occurrenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qac_ref", "qac_word_ref", "surah", "ayah", "word_index",
        "morpheme_index", "surface_ar", "stem_ar", "lemma_ar", "source_pos",
        "pos", "morpheme_role", "measure", "aspect", "mood", "voice",
        "morph_features", "ayah_ref", "form_id", "alignment"
      ],
      "properties": {
        "qac_ref": { "type": "string", "pattern": "^[0-9]+:[0-9]+:[0-9]+:[0-9]+$" },
        "qac_word_ref": { "type": "string", "pattern": "^[0-9]+:[0-9]+:[0-9]+$" },
        "surah": { "type": "integer", "minimum": 1 },
        "ayah": { "type": "integer", "minimum": 1 },
        "word_index": { "type": "integer", "minimum": 1 },
        "morpheme_index": { "type": "integer", "minimum": 1 },
        "surface_ar": { "type": "string" },
        "stem_ar": { "type": "string" },
        "lemma_ar": { "type": "string" },
        "source_pos": { "type": "string" },
        "pos": { "type": "string" },
        "morpheme_role": { "type": "string" },
        "measure": { "type": "string" },
        "aspect": { "type": "string" },
        "mood": { "type": "string" },
        "voice": { "type": "string" },
        "morph_features": { "type": "string" },
        "ayah_ref": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
        "form_id": { "type": "string", "pattern": "^F[0-9]{3}$" },
        "alignment": { "$ref": "#/$defs/alignmentRecord" }
      }
    },
    "alignmentRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "method", "confidence", "attachment_unit_id",
        "attachment_word_unit_id", "qac_char_span", "attachment_char_spans",
        "source_grammar", "attachments"
      ],
      "properties": {
        "status": { "enum": ["aligned", "unmatched", "ambiguous"] },
        "method": { "type": "string" },
        "confidence": { "type": "string" },
        "attachment_unit_id": { "type": "string" },
        "attachment_word_unit_id": { "type": "string" },
        "qac_char_span": { "$ref": "#/$defs/charSpan" },
        "attachment_char_spans": {
          "type": "array",
          "items": { "$ref": "#/$defs/charSpan" }
        },
        "source_grammar": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/attachmentDetail" }
        }
      }
    },
    "charSpan": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 0 }
    },
    "attachmentDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attachment_id", "relation", "focus_role", "other_unit_id",
        "other_surface", "other_root", "other_form_tag", "prep_base",
        "status", "confidence", "evidence"
      ],
      "properties": {
        "attachment_id": { "type": "string" },
        "relation": { "type": "string" },
        "focus_role": { "type": "string" },
        "other_unit_id": { "type": "string" },
        "other_surface": { "type": "string" },
        "other_root": { "type": "string" },
        "other_form_tag": { "type": "string" },
        "prep_base": { "type": "string" },
        "status": { "type": "string" },
        "confidence": { "type": "string" },
        "evidence": { "type": "string" }
      }
    },
    "occurrenceObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "statement", "evidence_refs"],
      "properties": {
        "category": {
          "enum": ["recurrent_pattern", "exception", "grammar", "translation_risk", "other"]
        },
        "statement": { "$ref": "#/$defs/prose" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    }
  }
}
