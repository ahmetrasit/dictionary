      "source_refs": "0395IbnFarisQazwini.MucjamMaqayis.JK008008-ara1:heading:170;jamhara:file=0321IbnDuraydAzdi.JamharatLugha.JK007100-ara1:section=heading%3A23:headword=%D8%A8%20%D8%AB%20%D8%AB:root=%D8%A8%20%D8%AB%20%D8%AB:sha=d97a7424db67e76e;sihah:file=0393IbnHammadJawhari.SihahTajLugha.Shamela0023235-ara1:section=heading%3A632:headword=%D8%A8%D8%AB%D8%AB:root=%D8%A8%20%D8%AB%20%D8%AB:sha=7de03fd100613b8d;tahdhib:file=tahdhib.sqlite_original:section=parent_entry_id%3D771%3Bsegment_index%3D4:headword=%D8%A8%D8%AB:root=%D8%A8%20%D8%AB:sha=4786273572aa2645;mufradat:file=0502RaghibIsbahani.Mufradat.Shamela0023636-ara1:section=heading%3A80:headword=%D8%A8%D8%AB:root=%D8%A8%20%D8%AB:sha=e1f45ea367e53be9",
