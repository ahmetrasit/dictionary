          "source_refs": "0395IbnFarisQazwini.MucjamMaqayis.JK008008-ara1:heading:2377;ayn:file=0170KhalilFarahidi.Cayn.JK000930-ara1:section=heading%3A967:headword=%D8%B9%D9%88%D8%AF:root=%D8%B9%20%D9%88%20%D8%AF:sha=7a121152627a1d98;sihah:file=0393IbnHammadJawhari.SihahTajLugha.Shamela0023235-ara1:section=heading%3A1361:headword=%D8%B9%D9%88%D8%AF:root=%D8%B9%20%D9%88%20%D8%AF:sha=72b975307562acb4;mufradat:file=0502RaghibIsbahani.Mufradat.Shamela0023636-ara1:section=heading%3A1054:headword=%D8%B9%D9%88%D8%AF:root=%D8%B9%20%D9%88%20%D8%AF:sha=34f3050583080bca",
