{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dictionary.local/v2/fragments/branch-writer.schema.json",
  "title": "Branch writer response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "root_id",
    "branch_id",
    "language",
    "image_transliteration",
    "summary",
    "source_discussion",
    "dictionary_annotations",
    "glosses",
    "arabic_neighbor_distinctions"
  ],
  "properties": {
    "root_id": { "$ref": "#/$defs/rootId" },
    "branch_id": { "$ref": "#/$defs/branchId" },
    "language": { "enum": ["en", "tr"] },
    "image_transliteration": { "$ref": "#/$defs/shortText" },
    "summary": { "$ref": "#/$defs/shortProse" },
    "source_discussion": { "$ref": "#/$defs/sourceDiscussion" },
    "dictionary_annotations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dictionaryAnnotation" }
    },
    "glosses": { "$ref": "#/$defs/glossSelection" },
    "arabic_neighbor_distinctions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/neighborDistinction" }
    }
  },
  "$defs": {
    "rootId": { "type": "string", "pattern": "^root_[0-9]{6}$" },
    "branchId": { "type": "string", "pattern": "^B[0-9]{3}$" },
    "sourceRef": { "type": "string", "minLength": 3, "maxLength": 1200 },
    "shortText": { "type": "string", "minLength": 2, "maxLength": 500 },
    "shortProse": { "type": "string", "minLength": 10, "maxLength": 1200 },
    "prose": { "type": "string", "minLength": 10, "maxLength": 3000 },
    "sourceDiscussion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discussion", "evidence_refs", "examples", "disagreement"],
      "properties": {
        "discussion": { "$ref": "#/$defs/prose" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "examples": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/sourceExample" }
        },
        "disagreement": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["summary", "source_refs"],
          "properties": {
            "summary": { "$ref": "#/$defs/shortProse" },
            "source_refs": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/sourceRef" }
            }
          }
        }
      }
    },
    "sourceExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arabic", "note", "source_refs"],
      "properties": {
        "arabic": { "$ref": "#/$defs/shortText" },
        "note": { "$ref": "#/$defs/shortProse" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    },
    "dictionaryAnnotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "roles", "contribution"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "base_definition",
              "corroboration",
              "boundary",
              "derivation",
              "example",
              "disagreement",
              "sole_attestation",
              "reading"
            ]
          }
        },
        "contribution": { "$ref": "#/$defs/shortProse" }
      }
    },
    "glossSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "excluded"],
      "properties": {
        "selected": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/selectedGloss" }
        },
        "excluded": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/excludedGloss" }
        }
      }
    },
    "selectedGloss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "text", "loanword_status", "error_profile"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1, "maximum": 3 },
        "text": { "$ref": "#/$defs/shortText" },
        "loanword_status": { "enum": ["none", "common", "specialist"] },
        "error_profile": { "$ref": "#/$defs/errorProfile" }
      }
    },
    "excludedGloss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "category", "exclusion_reason", "error_profile"],
      "properties": {
        "text": { "$ref": "#/$defs/shortText" },
        "category": { "enum": ["alternative", "common_loanword", "confusable"] },
        "exclusion_reason": { "$ref": "#/$defs/shortProse" },
        "error_profile": { "$ref": "#/$defs/errorProfile" }
      }
    },
    "errorProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fit", "preserves", "loses", "adds", "collision"],
      "properties": {
        "fit": {
          "enum": ["none", "narrowing", "broadening", "displacement", "drifted_loanword"]
        },
        "preserves": { "$ref": "#/$defs/shortProse" },
        "loses": { "$ref": "#/$defs/shortProse" },
        "adds": { "$ref": "#/$defs/shortProse" },
        "collision": { "$ref": "#/$defs/shortProse" }
      }
    },
    "neighborDistinction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "neighbor_root_id",
        "neighbor_branch_id",
        "expression_ar",
        "expression_transliteration",
        "gloss",
        "shared_zone",
        "distinction",
        "basis",
        "evidence_refs"
      ],
      "properties": {
        "neighbor_root_id": { "$ref": "#/$defs/rootId" },
        "neighbor_branch_id": { "$ref": "#/$defs/branchId" },
        "expression_ar": { "$ref": "#/$defs/shortText" },
        "expression_transliteration": { "$ref": "#/$defs/shortText" },
        "gloss": { "$ref": "#/$defs/shortText" },
        "shared_zone": { "$ref": "#/$defs/shortProse" },
        "distinction": { "$ref": "#/$defs/prose" },
        "basis": { "const": "furuq_branch_comparison" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    }
  }
}
