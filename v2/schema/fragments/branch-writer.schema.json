{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dictionary.local/v2/fragments/branch-writer.schema.json",
  "title": "Branch writer response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "root_id",
    "branch_id",
    "language",
    "image_transliteration",
    "summary",
    "concept_map",
    "identity_judgment",
    "lexicalization_scope",
    "source_summary",
    "source_synthesis",
    "usage_notes",
    "evidence_qualifiers",
    "lexical_glosses",
    "glosses",
    "arabic_neighbor_distinctions",
    "neighbor_coverage"
  ],
  "properties": {
    "root_id": { "$ref": "#/$defs/rootId" },
    "branch_id": { "$ref": "#/$defs/branchId" },
    "language": { "enum": ["en", "tr"] },
    "image_transliteration": { "$ref": "#/$defs/shortText" },
    "summary": { "$ref": "#/$defs/shortProse" },
    "concept_map": { "type": "object" },
    "identity_judgment": { "$ref": "#/$defs/identityJudgment" },
    "lexicalization_scope": { "$ref": "#/$defs/lexicalizationScope" },
    "source_summary": { "$ref": "#/$defs/prose" },
    "source_synthesis": { "type": "object" },
    "usage_notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/usageNote" }
    },
    "evidence_qualifiers": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceQualifier" }
    },
    "lexical_glosses": { "type": "array", "minItems": 0 },
    "glosses": { "$ref": "#/$defs/glossSelection" },
    "arabic_neighbor_distinctions": {
      "type": "array",
      "description": "Order by reader-facing importance; item 0 is the key distinction for the compact user dictionary.",
      "minItems": 0,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/neighborDistinction" }
    },
    "neighbor_coverage": { "$ref": "#/$defs/fragmentNeighborCoverage" }
  },
  "$defs": {
    "rootId": { "type": "string", "pattern": "^root_[0-9]{6}$" },
    "branchId": { "type": "string", "pattern": "^B[0-9]{3}$" },
    "shortText": { "type": "string", "minLength": 2, "maxLength": 500 },
    "shortProse": { "type": "string", "minLength": 10, "maxLength": 1200 },
    "prose": { "type": "string", "minLength": 10, "maxLength": 3000 },
    "identityJudgment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rationale", "boundary_note"],
      "properties": {
        "status": {
          "enum": [
            "accepted",
            "qualified",
            "reframed",
            "structural_review_required"
          ]
        },
        "rationale": { "$ref": "#/$defs/prose" },
        "boundary_note": { "$ref": "#/$defs/shortProse" }
      }
    },
    "lexicalizationScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch_kind", "note"],
      "properties": {
        "branch_kind": {
          "enum": [
            "bare",
            "collocation",
            "mixed_non_bare",
            "non_bare",
            "unresolved"
          ]
        },
        "note": { "$ref": "#/$defs/shortProse" }
      }
    },
    "usageNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "statement"],
      "properties": {
        "kind": {
          "enum": ["register", "constraint", "technical"]
        },
        "statement": { "$ref": "#/$defs/shortProse" }
      }
    },
    "evidenceQualifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "statement"],
      "properties": {
        "type": { "enum": ["disputed", "rare", "technical"] },
        "statement": { "$ref": "#/$defs/shortProse" }
      }
    },
    "glossSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantic_definition", "concept", "contextual", "selected", "excluded"],
      "properties": {
        "semantic_definition": { "$ref": "#/$defs/shortProse" },
        "concept": { "$ref": "#/$defs/selectedGloss" },
        "contextual": {
          "type": "array",
          "maxItems": 4,
          "items": { "$ref": "#/$defs/selectedGloss" }
        },
        "selected": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/selectedGloss" }
        },
        "excluded": {
          "type": "array",
          "minItems": 0,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/excludedGloss" }
        }
      }
    },
    "selectedGloss": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "text",
        "loanword_status",
        "usage_role",
        "selection_role",
        "applicability",
        "facet_ids",
        "error_profile"
      ],
      "properties": {
        "rank": { "type": "integer", "minimum": 1, "maximum": 5 },
        "text": { "$ref": "#/$defs/shortText" },
        "loanword_status": { "enum": ["none", "common", "specialist"] },
        "usage_role": {
          "enum": ["general", "contextual", "explanatory", "technical_term", "proper_name"]
        },
        "selection_role": {
          "enum": ["primary_concept_gloss", "contextual_gloss"]
        },
        "applicability": { "$ref": "#/$defs/shortProse" },
        "facet_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^F[0-9]{3}$" }
        },
        "error_profile": { "$ref": "#/$defs/errorProfile" }
      }
    },
    "excludedGloss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "category", "exclusion_reason", "error_profile"],
      "properties": {
        "text": { "$ref": "#/$defs/shortText" },
        "category": { "enum": ["alternative", "common_loanword", "confusable"] },
        "exclusion_reason": { "$ref": "#/$defs/shortProse" },
        "error_profile": { "$ref": "#/$defs/errorProfile" }
      }
    },
    "errorProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fit", "preserves", "loses", "adds", "collision"],
      "properties": {
        "fit": {
          "enum": ["none", "narrowing", "broadening", "displacement", "drifted_loanword"]
        },
        "preserves": { "$ref": "#/$defs/shortProse" },
        "loses": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "adds": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "collision": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 }
      }
    },
    "neighborDistinction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "neighbor_root_id",
        "neighbor_branch_id",
        "relation_type",
        "boundary_match",
        "focus_only",
        "neighbor_only",
        "expression_transliteration",
        "gloss",
        "shared_zone",
        "distinction"
      ],
      "properties": {
        "neighbor_root_id": { "$ref": "#/$defs/rootId" },
        "neighbor_branch_id": { "$ref": "#/$defs/branchId" },
        "relation_type": {
          "enum": [
            "synonym",
            "near_synonym",
            "antonym",
            "polarity_pair",
            "near_neighbor",
            "same_field",
            "thematic",
            "other"
          ]
        },
        "boundary_match": {
          "enum": ["exact", "partial", "opposed", "field_only", "thematic_only"]
        },
        "focus_only": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "neighbor_only": { "type": ["string", "null"], "minLength": 10, "maxLength": 1200 },
        "expression_transliteration": { "$ref": "#/$defs/shortText" },
        "gloss": { "$ref": "#/$defs/shortText" },
        "shared_zone": { "$ref": "#/$defs/shortProse" },
        "distinction": { "$ref": "#/$defs/prose" }
      }
    },
    "fragmentNeighborCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assessment", "note"],
      "properties": {
        "assessment": {
          "enum": [
            "none_useful",
            "complete",
            "single_sufficient",
            "legacy_minimum_unverified"
          ]
        },
        "note": { "$ref": "#/$defs/shortProse" }
      }
    }
  }
}
